# ============================================================
# OpenAI 嵌入模型配置
# 适合生产环境或需要高性能的场景
# ============================================================

# 嵌入模型提供商
EMBEDDING_PROVIDER=openai

# 嵌入向量维度
# text-embedding-ada-002: 1536
# text-embedding-3-small: 1536
# text-embedding-3-large: 3072
EMBEDDING_DIM=1536

# ============================================================
# OpenAI 配置
# ============================================================

# OpenAI API 基础地址
# 使用官方 OpenAI API:
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenAI 嵌入模型名称
# 推荐使用 text-embedding-3-small（性能更好，成本更低）
OPENAI_EMBED_MODEL=text-embedding-3-small

# OpenAI API 密钥（必填）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Zilliz Cloud 向量数据库配置
# ============================================================

# 注册 https://cloud.zilliz.com/ 获取 URI 和 API Token
ZILLIZ_URI=https://your-instance.serverless.gcp-us-west1.cloud.zilliz.com
ZILLIZ_TOKEN=your_zilliz_token_here

# Milvus 集合名称
# 规则: 以字母或下划线开头，仅允许字母、数字、下划线，最长 255 字符
COLLECTION_NAME=code_context

# ============================================================
# 索引配置
# ============================================================

# 扫描的文件扩展名（逗号分隔，可选）
# 默认值: .go,.vue,.js,.ts,.py,.md
SCAN_EXTENSIONS=.go,.vue,.js,.ts,.py,.md,.java,.cpp,.c,.cs,.rs,.php,.rb,.swift,.kt,.scala,.html,.css,.json,.yaml,.yml,.xml

# 降级切分时的块大小（rune 数，可选）
# 默认值: 800
CHUNK_SIZE=800

# 结构切分后超长块的最大 rune 数（可选）
# 默认值: 1500
MAX_CHUNK_SIZE=1500

# 是否启用自动索引（MCP 启动时自动检测并构建索引）
AUTO_INDEX=true

# MCP 模式下自动索引的项目路径（绝对路径）
PROJECT_PATH=/path/to/your/project

# 索引状态文件路径
# 默认值: {PROJECT_PATH}/.code-context-index-state.json
# INDEX_STATE_PATH=/path/to/.code-context-index-state.json

# ============================================================
# 使用说明
# ============================================================
#
# 1. 复制此文件为 .env
#    cp config-examples/.env.openai.example .env
#
# 2. 编辑 .env 文件:
#    - 填入你的 OpenAI API 密钥
#    - 填入你的 Zilliz Cloud 配置
#
# 3. 确保 EMBEDDING_DIM 与选择的模型匹配:
#    - text-embedding-ada-002: 1536
#    - text-embedding-3-small: 1536
#    - text-embedding-3-large: 3072
#
# 4. 运行 MCP 服务:
#    ./code-context-mcp
#
# 5. 或者在 OpenCode 配置文件中引用:
#    {
#      "mcpServers": {
#        "code-context": {
#          "command": "/path/to/code-context-mcp/start-mcp.sh",
#          "env": {
#            "EMBEDDING_PROVIDER": "openai",
#            "OPENAI_BASE_URL": "https://api.openai.com/v1",
#            "OPENAI_EMBED_MODEL": "text-embedding-3-small",
#            "OPENAI_API_KEY": "sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
#            "EMBEDDING_DIM": "1536",
#            "ZILLIZ_URI": "https://your-instance.serverless.gcp-us-west1.cloud.zilliz.com",
#            "ZILLIZ_TOKEN": "your_token_here"
#          }
#        }
#      }
#    }
