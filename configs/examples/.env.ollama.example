# ============================================================
# Ollama 嵌入模型配置（默认）
# 适合本地开发环境，使用本地 Ollama 服务
# ============================================================

# 嵌入模型提供商
EMBEDDING_PROVIDER=ollama

# 嵌入向量维度（nomic-embed-text 模型为 768）
EMBEDDING_DIM=768

# ============================================================
# Ollama 配置
# ============================================================

# Ollama 服务地址（本地运行）
# 如果 Ollama 运行在 Docker 中，使用: http://host.docker.internal:11434
OLLAMA_URL=http://localhost:11434

# Ollama 嵌入模型名称
# 常用模型:
# - nomic-embed-text:latest (默认，768维)
# - mxbai-embed-large:latest (1024维)
# - all-minilm:latest (384维)
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# ============================================================
# Zilliz Cloud 向量数据库配置
# ============================================================

# 注册 https://cloud.zilliz.com/ 获取 URI 和 API Token
ZILLIZ_URI=https://your-instance.serverless.gcp-us-west1.cloud.zilliz.com
ZILLIZ_TOKEN=your_zilliz_token_here

# Milvus 集合名称
# 规则: 以字母或下划线开头，仅允许字母、数字、下划线，最长 255 字符
COLLECTION_NAME=code_context

# ============================================================
# 索引配置
# ============================================================

# 扫描的文件扩展名（逗号分隔）
SCAN_EXTENSIONS=.go,.vue,.js,.ts,.py,.md,.java,.cpp,.c,.cs,.rs,.php,.rb,.swift,.kt,.scala,.html,.css,.json,.yaml,.yml,.xml

# 降级切分时的块大小（rune 数）
CHUNK_SIZE=800

# 结构切分后超长块的最大 rune 数
MAX_CHUNK_SIZE=1500

# 是否启用自动索引（MCP 启动时自动检测并构建索引）
AUTO_INDEX=true

# MCP 模式下自动索引的项目路径（绝对路径）
PROJECT_PATH=/path/to/your/project

# 索引状态文件路径
# 默认值: {PROJECT_PATH}/.code-context-index-state.json
# INDEX_STATE_PATH=/path/to/.code-context-index-state.json

# ============================================================
# 使用说明
# ============================================================
#
# 1. 复制此文件为 .env
#    cp config-examples/.env.ollama.example .env
#
# 2. 编辑 .env 文件，填入你的 Zilliz Cloud 配置
#
# 3. 确保 Ollama 服务正在运行:
#    ollama serve
#
# 4. 运行 MCP 服务:
#    ./code-context-mcp
#
# 5. 或者在 OpenCode 配置文件中引用:
#    {
#      "mcpServers": {
#        "code-context": {
#          "command": "/path/to/code-context-mcp/start-mcp.sh",
#          "env": {
#            "EMBEDDING_PROVIDER": "ollama",
#            "OLLAMA_URL": "http://localhost:11434",
#            "OLLAMA_EMBED_MODEL": "nomic-embed-text:latest",
#            "EMBEDDING_DIM": "768",
#            "ZILLIZ_URI": "https://your-instance.serverless.gcp-us-west1.cloud.zilliz.com",
#            "ZILLIZ_TOKEN": "your_token_here"
#          }
#        }
#      }
#    }