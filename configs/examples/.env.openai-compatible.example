# ============================================================
# OpenAI 兼容 API 配置
# 适用于 Azure OpenAI、OpenRouter、LiteLLM 等兼容服务
# ============================================================

# 嵌入模型提供商
EMBEDDING_PROVIDER=openai

# 嵌入向量维度（根据实际使用的模型调整）
# Azure OpenAI text-embedding-ada-002: 1536
# OpenRouter 模型: 查看对应模型的维度
EMBEDDING_DIM=1536

# ============================================================
# OpenAI 兼容 API 配置
# ============================================================

# API 基础地址（根据服务提供商调整）
# Azure OpenAI: https://{your-resource-name}.openai.azure.com/openai/deployments/{deployment-name}
# OpenRouter: https://openrouter.ai/api/v1
# LiteLLM 代理: http://localhost:4000
OPENAI_BASE_URL=https://your-api-endpoint.com/v1

# 模型名称（根据服务提供商调整）
# Azure OpenAI: 部署名称，如 text-embedding-ada-002
# OpenRouter: 模型标识符，如 openai/text-embedding-ada-002
OPENAI_EMBED_MODEL=text-embedding-ada-002

# API 密钥（必填）
OPENAI_API_KEY=your_api_key_here

# ============================================================
# Zilliz Cloud 向量数据库配置
# ============================================================

# 注册 https://cloud.zilliz.com/ 获取 URI 和 API Token
ZILLIZ_URI=https://your-instance.serverless.gcp-us-west1.cloud.zilliz.com
ZILLIZ_TOKEN=your_zilliz_token_here

# Milvus 集合名称
# 规则: 以字母或下划线开头，仅允许字母、数字、下划线，最长 255 字符
COLLECTION_NAME=code_context

# ============================================================
# 索引配置
# ============================================================

# 扫描的文件扩展名（逗号分隔）
SCAN_EXTENSIONS=.go,.vue,.js,.ts,.py,.md,.java,.cpp,.c,.cs,.rs,.php,.rb,.swift,.kt,.scala,.html,.css,.json,.yaml,.yml,.xml

# 降级切分时的块大小（rune 数）
CHUNK_SIZE=800

# 结构切分后超长块的最大 rune 数
MAX_CHUNK_SIZE=1500

# 是否启用自动索引（MCP 启动时自动检测并构建索引）
AUTO_INDEX=true

# MCP 模式下自动索引的项目路径（绝对路径）
PROJECT_PATH=/path/to/your/project

# 索引状态文件路径
# 默认值: {PROJECT_PATH}/.code-context-index-state.json
# INDEX_STATE_PATH=/path/to/.code-context-index-state.json

# ============================================================
# 常见服务配置示例
# ============================================================

# ============================================================
# Azure OpenAI 示例配置
# ============================================================
# EMBEDDING_PROVIDER=openai
# EMBEDDING_DIM=1536
# OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
# OPENAI_EMBED_MODEL=text-embedding-ada-002
# OPENAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# 注意：Azure OpenAI 需要在请求头中添加 API 版本，通常由 SDK 处理
# 如果你的代理或服务需要特殊处理，请参考对应文档

# ============================================================
# OpenRouter 示例配置
# ============================================================
# EMBEDDING_PROVIDER=openai
# EMBEDDING_DIM=1536
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_EMBED_MODEL=openai/text-embedding-ada-002
# OPENAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# 注意：OpenRouter 需要添加额外的请求头，通常由 SDK 处理

# ============================================================
# LiteLLM 代理示例配置
# ============================================================
# EMBEDDING_PROVIDER=openai
# EMBEDDING_DIM=1536
# OPENAI_BASE_URL=http://localhost:4000
# OPENAI_EMBED_MODEL=text-embedding-ada-002
# OPENAI_API_KEY=your-lite-llm-api-key
#
# 注意：LiteLLM 可以作为代理，支持多种模型提供商

# ============================================================
# 使用说明
# ============================================================
#
# 1. 复制此文件为 .env
#    cp config-examples/.env.openai-compatible.example .env
#
# 2. 根据你的服务提供商修改配置:
#    - OPENAI_BASE_URL: 服务商的 API 地址
#    - OPENAI_EMBED_MODEL: 模型标识符
#    - OPENAI_API_KEY: 服务商的 API 密钥
#    - EMBEDDING_DIM: 根据模型维度调整
#
# 3. 填入 Zilliz Cloud 配置
#
# 4. 运行 MCP 服务:
#    ./code-context-mcp
#
# 5. 或者在 OpenCode 配置文件中引用:
#    {
#      "mcpServers": {
#        "code-context": {
#          "command": "/path/to/code-context-mcp/start-mcp.sh",
#          "env": {
#            "EMBEDDING_PROVIDER": "openai",
#            "OPENAI_BASE_URL": "https://your-api-endpoint.com/v1",
#            "OPENAI_EMBED_MODEL": "your-model-name",
#            "OPENAI_API_KEY": "your_api_key_here",
#            "EMBEDDING_DIM": "1536",
#            "ZILLIZ_URI": "https://your-instance.serverless.gcp-us-west1.cloud.zilliz.com",
#            "ZILLIZ_TOKEN": "your_token_here"
#          }
#        }
#      }
#    }