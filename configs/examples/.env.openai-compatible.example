# ============================================================
# OpenAI 兼容嵌入模型 + 本地 JSONL 向量存储 配置模板
# ============================================================

# 嵌入模型提供商（固定为 openai）
EMBEDDING_PROVIDER=openai

# 嵌入向量维度（根据实际模型调整）
# text-embedding-ada-002: 1536
# text-embedding-3-small: 1536
# text-embedding-3-large: 3072 或 1024/256
EMBEDDING_DIM=1536

# API 基础地址
# Azure OpenAI: https://{resource}.openai.azure.com/openai/deployments/{deployment}
# OpenRouter:   https://openrouter.ai/api/v1
# LiteLLM:      http://localhost:4000
OPENAI_BASE_URL=https://your-api-endpoint.com/v1

# 模型名称
OPENAI_EMBED_MODEL=text-embedding-ada-002

# API 密钥
OPENAI_API_KEY=your_api_key_here

# 向量存储（固定为 local，使用 JSONL 文件）
VECTOR_STORE=local

# JSONL 文件生成路径（默认: code-text/code_context.jsonl，可自定义）
# VECTOR_STORE_PATH=/path/to/code-text/my_project.jsonl

# 集合名称（决定 JSONL 文件名: {COLLECTION_NAME}.jsonl）
# COLLECTION_NAME=code_context

# 扫描的文件扩展名（逗号分隔）
# SCAN_EXTENSIONS=.go,.vue,.js,.ts,.py,.md

# 自动索引的项目路径（MCP 启动时自动构建索引）
PROJECT_PATH=/path/to/your/project

# 是否启用自动索引（默认: true）
# AUTO_INDEX=true

# 降级切分的块大小（默认: 800）
# CHUNK_SIZE=800

# 结构切分后超长块的最大 rune 数（默认: 1500）
# MAX_CHUNK_SIZE=1500
