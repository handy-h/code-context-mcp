# ============================================================
# 嵌入模型配置
# ============================================================

# 嵌入模型提供商 (支持: ollama, openai)
# 默认值: ollama
EMBEDDING_PROVIDER=ollama

# 嵌入向量维度
# Ollama nomic-embed-text: 768
# OpenAI text-embedding-ada-002: 1536
# 默认值: 768
EMBEDDING_DIM=768

# ============================================================
# Ollama 配置 (当 EMBEDDING_PROVIDER=ollama 时使用)
# ============================================================

# Ollama 服务地址
# 默认值: http://localhost:11434
OLLAMA_URL=http://localhost:11434

# Ollama 嵌入模型名称（需已在 Ollama 中拉取）
# 默认值: nomic-embed-text:latest
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# ============================================================
# OpenAI 兼容 API 配置 (当 EMBEDDING_PROVIDER=openai 时使用)
# ============================================================

# OpenAI 兼容 API 基础地址
# 例如: https://api.openai.com/v1 或 https://api.example.com/v1
# 默认值: https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenAI 嵌入模型名称
# 例如: text-embedding-ada-002, text-embedding-3-small, text-embedding-3-large
# 默认值: text-embedding-ada-002
OPENAI_EMBED_MODEL=text-embedding-ada-002

# OpenAI API 密钥 (必需)
OPENAI_API_KEY=your_openai_api_key_here

# ============================================================
# Zilliz Cloud 向量数据库配置
# ============================================================
# 注册 https://cloud.zilliz.com/ 获取 URI 和 API Token

# Zilliz Cloud 实例 URI
ZILLIZ_URI=https://your-instance.serverless.gcp-us-west1.cloud.zilliz.com

# Zilliz Cloud API Token
ZILLIZ_TOKEN=your_zilliz_token_here

# Milvus 集合名称
# 规则: 以字母或下划线开头，仅允许字母、数字、下划线，最长 255 字符
# 非法字符将被自动替换为下划线
# 默认值: code_context
COLLECTION_NAME=code_context

# ============================================================
# 索引配置
# ============================================================

# 扫描的文件扩展名（逗号分隔）
# 默认值: .go,.vue,.js,.ts,.py,.md
SCAN_EXTENSIONS=.go,.vue,.js,.ts,.py,.md

# 降级切分时的块大小（rune 数）
# 默认值: 800
CHUNK_SIZE=800

# 结构切分后超长块的最大 rune 数
# 默认值: 1500
MAX_CHUNK_SIZE=1500

# ============================================================
# 自动索引配置
# ============================================================

# 是否启用自动索引（MCP 启动时自动检测并构建索引）
# 可选值: true / false
# 默认值: true
AUTO_INDEX=true

# MCP 模式下自动索引的项目路径（绝对路径）
PROJECT_PATH=/path/to/your/project

# 索引状态文件路径
# 默认值: {PROJECT_PATH}/.code-context-index-state.json
# INDEX_STATE_PATH=/path/to/.code-context-index-state.json
