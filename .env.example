# Ollama 嵌入模型配置
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
EMBEDDING_DIM=768

# Zilliz Cloud 向量数据库配置
# 注册 https://cloud.zilliz.com/ 获取 URI 和 API Token
ZILLIZ_URI=https://your-instance.serverless.gcp-us-west1.cloud.zilliz.com
ZILLIZ_TOKEN=your_zilliz_token_here
COLLECTION_NAME=code-context

# 索引配置
# 扫描的文件扩展名（逗号分隔）
SCAN_EXTENSIONS=.go,.vue,.js,.ts,.py,.md
# 降级切分时的块大小（rune）
CHUNK_SIZE=800
# 结构切分后超长块的最大 rune 数
MAX_CHUNK_SIZE=1500

# 自动索引配置
# 是否启用自动索引（MCP 启动时自动检测并构建索引）
AUTO_INDEX=true
# MCP 模式下自动索引的项目路径
PROJECT_PATH=/path/to/your/project
# 索引状态文件路径（默认 {PROJECT_PATH}/.code-context-index-state.json）
# INDEX_STATE_PATH=/path/to/.code-context-index-state.json
