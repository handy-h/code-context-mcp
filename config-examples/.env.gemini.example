# ============================================================
# Google Gemini 嵌入模型配置
# 使用 Google Gemini Embeddings API
# ============================================================

# 嵌入模型提供商
EMBEDDING_PROVIDER=gemini

# 嵌入向量维度
# Gemini embedding-001: 768 维
EMBEDDING_DIM=768

# ============================================================
# Google Gemini 配置
# ============================================================

# Google Gemini API 基础地址
# 官方 API 地址: https://generativelanguage.googleapis.com/v1beta
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Gemini 嵌入模型名称
# 注意: Gemini 模型名称格式为 "models/embedding-001"
# 如果是 embedding-001，API 路径会自动添加 models/ 前缀
GEMINI_EMBED_MODEL=embedding-001

# Gemini API 密钥（必填）
# 在 Google AI Studio 获取: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Zilliz Cloud 向量数据库配置
# ============================================================

# 注册 https://cloud.zilliz.com/ 获取 URI 和 API Token
ZILLIZ_URI=https://your-instance.serverless.gcp-us-west1.cloud.zilliz.com
ZILLIZ_TOKEN=your_zilliz_token_here

# Milvus 集合名称
# 规则: 以字母或下划线开头，仅允许字母、数字、下划线，最长 255 字符
COLLECTION_NAME=code_context

# ============================================================
# 索引配置
# ============================================================

# 扫描的文件扩展名（逗号分隔）
SCAN_EXTENSIONS=.go,.vue,.js,.ts,.py,.md,.java,.cpp,.c,.cs,.rs,.php,.rb,.swift,.kt,.scala,.html,.css,.json,.yaml,.yml,.xml

# 降级切分时的块大小（rune 数）
CHUNK_SIZE=800

# 结构切分后超长块的最大 rune 数
MAX_CHUNK_SIZE=1500

# 是否启用自动索引（MCP 启动时自动检测并构建索引）
AUTO_INDEX=true

# MCP 模式下自动索引的项目路径（绝对路径）
PROJECT_PATH=/path/to/your/project

# 索引状态文件路径
# 默认值: {PROJECT_PATH}/.code-context-index-state.json
# INDEX_STATE_PATH=/path/to/.code-context-index-state.json

# ============================================================
# 使用说明
# ============================================================
#
# 1. 获取 Gemini API 密钥:
#    - 访问 https://makersuite.google.com/app/apikey
#    - 创建 API 密钥
#
# 2. 复制此文件为 .env
#    cp config-examples/.env.gemini.example .env
#
# 3. 编辑 .env 文件:
#    - 填入你的 Gemini API 密钥
#    - 填入你的 Zilliz Cloud 配置
#
# 4. 确保 EMBEDDING_DIM 设置为 768（Gemini embedding-001 的维度）
#
# 5. 运行 MCP 服务:
#    ./code-context-mcp
#
# 6. 或者在 OpenCode 配置文件中引用:
#    {
#      "mcpServers": {
#        "code-context": {
#          "command": "/path/to/code-context-mcp/start-mcp.sh",
#          "env": {
#            "EMBEDDING_PROVIDER": "gemini",
#            "GEMINI_BASE_URL": "https://generativelanguage.googleapis.com/v1beta",
#            "GEMINI_EMBED_MODEL": "embedding-001",
#            "GEMINI_API_KEY": "AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
#            "EMBEDDING_DIM": "768",
#            "ZILLIZ_URI": "https://your-instance.serverless.gcp-us-west1.cloud.zilliz.com",
#            "ZILLIZ_TOKEN": "your_token_here",
#            "PROJECT_PATH": "/path/to/your/project"
#          }
#        }
#      }
#    }
#
# 注意: Gemini Embeddings API 使用 x-goog-api-key 头部，但代码中已经处理为 URL 参数方式
# API 调用格式: https://generativelanguage.googleapis.com/v1beta/models/embedding-001:embedContent?key=YOUR_API_KEY